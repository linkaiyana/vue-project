{
  "name": "vue-project",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --",
    "dev:test": "vite --mode test --",
    "dev:prod": "vite --mode production --",
    "prepare": "simple-git-hooks",
    "check": "esno ./commands/customScripts.ts check",
    "build": "esno ./commands/customScripts.ts build",
    "build:test": "esno ./commands/customScripts.ts build:test",
    "build:shared": "esno ./commands/buildSharedVendors.ts",
    "lint": "eslint .  --cache",
    "lint:fix": "eslint . --fix --cache",
    "lint-staged": "lint-staged",
    "lint:project": "esno ./commands/customScripts.ts lint",
    "lint:project:fix": "esno ./commands/customScripts.ts lint:fix",
    "preview": "esno ./commands/customScripts.ts preview",
    "createActivity": "esno ./commands/createActivity.ts",
    "fontMin": "esno ./commands/fontMin.ts",
    "fetchLanguage": "esno ./commands/fetchLanguage"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,vue,json,md,scss,css,yml,yaml}": [
      "eslint --fix --cache --max-warnings=0 --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.1.0",
    "@sentry/vue": "^10.46.0",
    "pinia": "^3.0.4",
    "svga": "2.1.1",
    "unplugin-auto-import": "^20.3.0",
    "vant": "^4.9.22",
    "vue": "3.5.26",
    "vue-i18n": "11.2.8",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.1",
    "@unocss/eslint-plugin": "^66.5.12",
    "@unocss/reset": "^66.5.12",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.2.0",
    "esno": "^4.8.0",
    "fontmin": "^1.1.1",
    "googleapis": "^168.0.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "ora": "^9.0.0",
    "picocolors": "^1.1.1",
    "postcss-px-to-viewport-8-plugin": "^1.2.5",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.97.2",
    "simple-git-hooks": "^2.13.1",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "unocss": "^66.5.12",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.2.4",
    "vite-plugin-pages": "^0.33.2",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.1.5",
    "lint-staged": "^16.2.7"
  }
}
